# Vendor API Configuration
# For iOS Simulator and Android Emulator, use your computer's IP address
# Replace 192.168.1.164 with your actual local IP address
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.164:8000
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_API_TIMEOUT=30000

# Alternative configurations:
# For iOS Simulator only: http://localhost:8000
# For Android Emulator only: http://10.0.2.2:8000
# For physical device: http://YOUR_COMPUTER_IP:8000

# Development Configuration
EXPO_PUBLIC_ENV=development

# Mock API Mode (perfect for presentations & demos!)
# Set to 'true' to use mock data instead of real API
# Set to 'false' to connect to real backend
EXPO_PUBLIC_USE_MOCK_API=false

# Production Configuration (uncomment for production)
# EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com
# EXPO_PUBLIC_ENV=production
# EXPO_PUBLIC_API_TIMEOUT=15000

# Staging Configuration (uncomment for staging)
# EXPO_PUBLIC_API_BASE_URL=https://api-staging.yourdomain.com
# EXPO_PUBLIC_ENV=staging
# EXPO_PUBLIC_API_TIMEOUT=20000